<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MagicMirror.Native.Pages.MirrorPage"
             Title="Mirror"
             BackgroundColor="#060912">
    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="Section" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="#DCE9FF" />
                <Setter Property="Margin" Value="2,8,0,0" />
            </Style>
            <Style x:Key="Field" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="#8FB4D4" />
                <Setter Property="Margin" Value="2,0,0,0" />
            </Style>
            <Style TargetType="Picker">
                <Setter Property="TextColor" Value="#E6EDF3" />
                <Setter Property="BackgroundColor" Value="#0E1730" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="#E6EDF3" />
                <Setter Property="BackgroundColor" Value="#0E1730" />
                <Setter Property="FontSize" Value="13" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!-- Deep space gradient backdrop -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#060912" Offset="0" />
                <GradientStop Color="#0A1024" Offset="0.5" />
                <GradientStop Color="#0C0A1E" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Ambient glow orbs (animated) -->
        <Ellipse x:Name="OrbCyan" WidthRequest="320" HeightRequest="320" Opacity="0.22"
                 HorizontalOptions="Start" VerticalOptions="Start" Margin="-90,-110,0,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#22E5FF" Offset="0" />
                    <GradientStop Color="#0022E5FF" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse x:Name="OrbViolet" WidthRequest="360" HeightRequest="360" Opacity="0.20"
                 HorizontalOptions="End" VerticalOptions="Start" Margin="0,40,-120,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#A855F7" Offset="0" />
                    <GradientStop Color="#00A855F7" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <ScrollView>
            <VerticalStackLayout Padding="20,18" Spacing="16">

                <!-- Hero -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Margin="0,4,0,2">
                    <Border Grid.Column="0" WidthRequest="64" HeightRequest="64" StrokeThickness="0"
                            VerticalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A2A55" Offset="0" />
                                <GradientStop Color="#2A1A55" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow x:Name="HeroShadow" Brush="#22E5FF" Offset="0,0" Radius="26" Opacity="0.6" />
                        </Border.Shadow>
                        <Label x:Name="HeroIcon" Text="🪞" FontSize="32"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="المرآة السحرية" FontSize="23" FontAttributes="Bold" TextColor="#EAF3FF" />
                        <Label Text="MAGIC MIRROR · neural translation lens" FontSize="11"
                               TextColor="#6FA8D8" CharacterSpacing="2" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Launch button -->
                <Border StrokeThickness="0" HeightRequest="58">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#3B82F6" Offset="0,0" Radius="22" Opacity="0.7" />
                    </Border.Shadow>
                    <Button x:Name="BtnOpen" Text="◈   فتح نافذة المرآة" Clicked="OnOpenMirror"
                            TextColor="White" FontAttributes="Bold" FontSize="16" CornerRadius="16">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#22E5FF" Offset="0" />
                                <GradientStop Color="#3B82F6" Offset="0.55" />
                                <GradientStop Color="#A855F7" Offset="1" />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Border>

                <!-- Status card (glass) -->
                <Border Padding="16" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3322E5FF" Offset="0" />
                            <GradientStop Color="#33A855F7" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Stroke>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#CC0C1730" Offset="0" />
                            <GradientStop Color="#990A0F22" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="7">
                        <Label Text="◢ SYSTEM STATUS" FontSize="11" TextColor="#22E5FF" CharacterSpacing="2" />
                        <Label x:Name="LblCapture" Text="Capture: …" FontSize="12" TextColor="#AFC6E0" />
                        <Label x:Name="LblOcr" Text="OCR: …" FontSize="12" TextColor="#AFC6E0" />
                        <Label x:Name="LblAi" Text="AI gateway: …" FontSize="12" TextColor="#AFC6E0" />
                    </VerticalStackLayout>
                </Border>

                <!-- Translation settings (glass) -->
                <Border Padding="16" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.Stroke><SolidColorBrush Color="#243150" /></Border.Stroke>
                    <Border.Background><SolidColorBrush Color="#B30B1226" /></Border.Background>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="◇ TRANSLATION" Style="{StaticResource Section}" TextColor="#22E5FF" />

                        <Label Text="Translate into (main language)" Style="{StaticResource Field}" />
                        <Picker x:Name="PickerTarget" />

                        <Label Text="Original text language (OCR source)" Style="{StaticResource Field}" />
                        <Picker x:Name="PickerSource" />

                        <Label Text="OCR engine" Style="{StaticResource Field}" />
                        <Picker x:Name="PickerOcr" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,4,0,0">
                            <Switch Grid.Column="0" x:Name="SwitchWindowText" OnColor="#22E5FF" ThumbColor="#EAF3FF" />
                            <Label Grid.Column="1" Text="Read text from window (skip OCR when available)"
                                   FontSize="12" TextColor="#8FB4D4" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Overlay appearance (glass) -->
                <Border Padding="16" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.Stroke><SolidColorBrush Color="#243150" /></Border.Stroke>
                    <Border.Background><SolidColorBrush Color="#B30B1226" /></Border.Background>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="◇ OVERLAY" Style="{StaticResource Section}" TextColor="#A855F7" />

                        <Label x:Name="LblDim" Text="Dimming" Style="{StaticResource Field}" />
                        <Slider x:Name="SliderDim" Minimum="0" Maximum="0.85" ValueChanged="OnDimChanged"
                                MinimumTrackColor="#22E5FF" MaximumTrackColor="#243150" ThumbColor="#22E5FF" />

                        <Label Text="Translated text background color (#RRGGBB)" Style="{StaticResource Field}" />
                        <Entry x:Name="EntryTranslationBackgroundColor" Placeholder="#F3F6EF" PlaceholderColor="#52708F" />

                        <Label x:Name="LblTranslationBackgroundOpacity" Text="Text background opacity" Style="{StaticResource Field}" />
                        <Slider x:Name="SliderTranslationBackgroundOpacity" Minimum="0" Maximum="1" ValueChanged="OnTranslationBackgroundOpacityChanged"
                                MinimumTrackColor="#F3F6EF" MaximumTrackColor="#243150" ThumbColor="#F3F6EF" />

                        <Label Text="Translated font color (#RRGGBB)" Style="{StaticResource Field}" />
                        <Entry x:Name="EntryTranslationTextColor" Placeholder="#0D0F14" PlaceholderColor="#52708F" />

                        <Label x:Name="LblScale" Text="Text size" Style="{StaticResource Field}" />
                        <Slider x:Name="SliderScale" Minimum="0.75" Maximum="3" ValueChanged="OnScaleChanged"
                                MinimumTrackColor="#22E5FF" MaximumTrackColor="#243150" ThumbColor="#22E5FF" />

                        <Label x:Name="LblLineSpacing" Text="Line spacing" Style="{StaticResource Field}" />
                        <Slider x:Name="SliderLineSpacing" Minimum="0.85" Maximum="1.6" ValueChanged="OnLineSpacingChanged"
                                MinimumTrackColor="#00FFA3" MaximumTrackColor="#243150" ThumbColor="#00FFA3" />

                        <Label Text="Text arrangement" Style="{StaticResource Field}" />
                        <Picker x:Name="PickerLayout" />

                        <Label x:Name="LblFps" Text="Live preview FPS" Style="{StaticResource Field}" />
                        <Slider x:Name="SliderFps" Minimum="0" Maximum="12" ValueChanged="OnFpsChanged"
                                MinimumTrackColor="#A855F7" MaximumTrackColor="#243150" ThumbColor="#A855F7" />
                    </VerticalStackLayout>
                </Border>

                <!-- AI + OCR engine (glass) -->
                <Border Padding="16" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.Stroke><SolidColorBrush Color="#243150" /></Border.Stroke>
                    <Border.Background><SolidColorBrush Color="#B30B1226" /></Border.Background>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="◇ AI &amp; ENGINE" Style="{StaticResource Section}" TextColor="#3B82F6" />

                        <Label Text="AI gateway base URL (your deployed web layer; blank = MT fallback only)"
                               Style="{StaticResource Field}" />
                        <Entry x:Name="EntryGateway" Placeholder="https://your-app.pages.dev" PlaceholderColor="#52708F" />

                        <Label Text="AI model" Style="{StaticResource Field}" />
                        <Entry x:Name="EntryModel" />

                        <Label Text="Tesseract languages" Style="{StaticResource Field}" />
                        <Entry x:Name="EntryTessLangs" />

                        <Label Text="tessdata directory (THEORYS eng+ara)" Style="{StaticResource Field}" />
                        <Entry x:Name="EntryTessData" />

                        <Label Text="tesseract.exe path (blank = auto-discover)" Style="{StaticResource Field}" />
                        <Entry x:Name="EntryTessExe" />
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="0" HeightRequest="48">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="#00FFA3" Offset="0,0" Radius="16" Opacity="0.55" /></Border.Shadow>
                    <Button x:Name="BtnSave" Text="⬢  حفظ الإعدادات" Clicked="OnSave"
                            TextColor="#04140C" FontAttributes="Bold" FontSize="14" CornerRadius="14">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00FFA3" Offset="0" />
                                <GradientStop Color="#22E5FF" Offset="1" />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Border>

                <Label x:Name="LblSaved" Text="" FontSize="12" TextColor="#3FFFB0" HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
