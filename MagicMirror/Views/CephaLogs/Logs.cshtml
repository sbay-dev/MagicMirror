@{
    ViewData["Title"] = "System Logs";
}
<div class="cepha-card" style="margin-bottom:1.5rem">
  <div class="cepha-card-header">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem">
      <h2 style="margin:0;color:var(--cepha-text)">📋 System Logs</h2>
      <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap">
        <button class="cepha-btn cepha-btn-sm cepha-btn-primary cepha-log-level-btn active" data-level="ALL">ALL</button>
        <button class="cepha-btn cepha-btn-sm cepha-btn-secondary cepha-log-level-btn" data-level="DEBUG">DEBUG</button>
        <button class="cepha-btn cepha-btn-sm cepha-btn-secondary cepha-log-level-btn" data-level="INFO">INFO</button>
        <button class="cepha-btn cepha-btn-sm cepha-btn-secondary cepha-log-level-btn" data-level="WARN">WARN</button>
        <button class="cepha-btn cepha-btn-sm cepha-btn-secondary cepha-log-level-btn" data-level="ERROR">ERROR</button>
        <button class="cepha-btn cepha-btn-sm cepha-btn-secondary cepha-log-level-btn" data-level="FATAL">FATAL</button>
      </div>
    </div>
    <div style="margin-top:.5rem;display:flex;gap:.75rem;align-items:center;flex-wrap:wrap">
      <span class="cepha-badge" id="cepha-log-count" style="background:var(--cepha-primary);color:#fff">0 entries</span>
      <span class="cepha-badge" id="syslog-session" style="background:var(--cepha-primary);color:#fff">—</span>
    </div>
  </div>
</div>

<!-- Tab Navigation -->
<div class="cepha-card" style="margin-bottom:0;border-bottom-left-radius:0;border-bottom-right-radius:0">
  <div class="cepha-logs-tabs">
    <button class="cepha-logs-tab active" data-tab="server">🖥️ Server Logs</button>
    <button class="cepha-logs-tab" data-tab="security">🛡️ Security</button>
    <button class="cepha-logs-tab" data-tab="repairs">🔧 Repairs</button>
    <button class="cepha-logs-tab" data-tab="anomaly">🧠 Anomaly</button>
  </div>
</div>

<!-- Server Logs Tab -->
<div class="cepha-tab-panel active cepha-card" data-panel="server" data-cepha-secure-skip data-cepha-stream-skip style="border-top-left-radius:0;border-top-right-radius:0;margin-bottom:1.5rem">
  <div class="cepha-card-body">
    <div style="max-height:60vh;overflow-y:auto">
      <table class="cepha-table cepha-table-sm" style="font-family:var(--cepha-font-mono);font-size:.8rem">
        <thead><tr><th style="width:180px">Time</th><th style="width:80px">Level</th><th style="width:100px">Category</th><th>Message</th></tr></thead>
        <tbody id="server-log-body"></tbody>
      </table>
    </div>
    <p class="cepha-text-secondary" id="cepha-no-logs" style="padding:2rem;text-align:center">No log entries yet. Logs appear here as the application runs.</p>
  </div>
</div>

<!-- Security SysLog Tab -->
<div class="cepha-tab-panel cepha-card" data-panel="security" data-cepha-secure-skip data-cepha-stream-skip style="display:none;border-top-left-radius:0;border-top-right-radius:0;margin-bottom:1.5rem">
  <div class="cepha-card-body">
    <div style="display:flex;gap:.75rem;margin-bottom:1rem;flex-wrap:wrap">
      <span class="cepha-badge" id="sec-count" style="background:#f44336;color:#fff">0 violations</span>
      <span class="cepha-badge" id="sec-enforced" style="background:#ff9800;color:#fff">—</span>
    </div>
    <div style="max-height:60vh;overflow-y:auto">
      <table class="cepha-table cepha-table-sm" style="font-family:var(--cepha-font-mono);font-size:.8rem">
        <thead><tr><th style="width:180px">Time</th><th style="width:70px">Level</th><th style="width:150px">Type</th><th>Detail</th><th style="width:200px">DOM Path</th></tr></thead>
        <tbody id="sec-log-body"></tbody>
      </table>
    </div>
    <p class="cepha-text-secondary" id="sec-no-logs" style="padding:2rem;text-align:center">No security events yet. CephaSecurity monitors DOM integrity in real-time.</p>
  </div>
</div>

<!-- Repairs Tab -->
<div class="cepha-tab-panel cepha-card" data-panel="repairs" data-cepha-secure-skip data-cepha-stream-skip style="display:none;border-top-left-radius:0;border-top-right-radius:0;margin-bottom:1.5rem">
  <div class="cepha-card-body">
    <div style="display:flex;gap:.75rem;margin-bottom:1rem;flex-wrap:wrap">
      <span class="cepha-badge" id="repair-count" style="background:#4caf50;color:#fff">0 repairs</span>
      <span class="cepha-badge" id="repair-pending" style="background:#ff9800;color:#fff">0 pending</span>
    </div>
    <div style="max-height:60vh;overflow-y:auto">
      <table class="cepha-table cepha-table-sm" style="font-family:var(--cepha-font-mono);font-size:.8rem">
        <thead><tr><th style="width:180px">Time</th><th style="width:80px">Status</th><th style="width:150px">Violation</th><th>Action</th><th style="width:200px">DOM Path</th></tr></thead>
        <tbody id="repair-log-body"></tbody>
      </table>
    </div>
    <p class="cepha-text-secondary" id="repair-no-logs" style="padding:2rem;text-align:center">No repair actions yet. Repairs occur when enforcement is enabled and violations are detected.</p>
  </div>
</div>

<!-- Anomaly Summary Tab -->
<div class="cepha-tab-panel cepha-card" data-panel="anomaly" data-cepha-secure-skip data-cepha-stream-skip style="display:none;border-top-left-radius:0;border-top-right-radius:0;margin-bottom:1.5rem">
  <div class="cepha-card-body">
    <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:1.5rem">
      <div class="cepha-card" style="flex:1;min-width:180px;padding:1rem;text-align:center">
        <div style="font-size:2rem;font-weight:700;color:#f44336" id="anomaly-violations">0</div>
        <div class="cepha-caption">Total Violations</div>
      </div>
      <div class="cepha-card" style="flex:1;min-width:180px;padding:1rem;text-align:center">
        <div style="font-size:2rem;font-weight:700;color:#4caf50" id="anomaly-repairs">0</div>
        <div class="cepha-caption">Successful Repairs</div>
      </div>
      <div class="cepha-card" style="flex:1;min-width:180px;padding:1rem;text-align:center">
        <div style="font-size:2rem;font-weight:700;color:#ff9800" id="anomaly-failed">0</div>
        <div class="cepha-caption">Worker Heals</div>
      </div>
    </div>
    <h3 style="margin:0 0 .75rem 0;font-size:1rem;color:var(--cepha-text)">Violations by Type</h3>
    <div id="anomaly-by-type" style="margin-bottom:1.5rem"></div>
    <h3 style="margin:0 0 .75rem 0;font-size:1rem;color:var(--cepha-text)">Violations by Level</h3>
    <div id="anomaly-by-level" style="margin-bottom:1.5rem"></div>
    <div style="text-align:right;margin-top:1rem">
      <button class="cepha-btn cepha-btn-sm cepha-btn-primary" id="anomaly-export-btn">⬇ Export JSONL (ML Ready)</button>
    </div>
  </div>
</div>

<style>
.cepha-log-level-btn.active { background: var(--cepha-primary) !important; color: #fff !important; border-color: var(--cepha-primary) !important; }
.cepha-log-row-error { color: #f44336; }
.cepha-log-row-fatal { color: #b71c1c; font-weight: 700; }
.cepha-log-row-warn { color: #ff9800; }
.cepha-log-row-info { color: var(--cepha-primary); }
.cepha-log-row-debug { color: var(--cepha-text-secondary); }
.cepha-log-row-trace { color: var(--cepha-text-secondary); opacity: .7; }
.anomaly-bar { height: 24px; border-radius: 4px; display: flex; align-items: center; padding: 0 8px; font-size: .75rem; font-weight: 600; color: #fff; margin-bottom: 4px; min-width: 40px; transition: width .3s ease; }
</style>

<script>
(function() {
    // Re-initialize on each navigation to logs (Worker replaces #app each time)
    var _activeLevel = 'ALL';
    var _updatePending = false;

    // Tab switching — uses event delegation via document
    document.addEventListener('click', function(e) {
        var tab = e.target.closest('.cepha-logs-tab');
        if (!tab) return;
        document.querySelectorAll('.cepha-logs-tab').forEach(function(t) {
            t.classList.remove('active');
        });
        document.querySelectorAll('.cepha-tab-panel').forEach(function(p) {
            p.style.display = 'none';
        });
        tab.classList.add('active');
        var panel = document.querySelector('[data-panel="' + tab.getAttribute('data-tab') + '"]');
        if (panel) panel.style.display = 'block';
        scheduleUpdate();
    });

    // Level filter buttons — uses event delegation
    document.addEventListener('click', function(e) {
        var btn = e.target.closest('.cepha-log-level-btn');
        if (!btn) return;
        document.querySelectorAll('.cepha-log-level-btn').forEach(function(b) {
            b.classList.remove('active');
            b.className = b.className.replace('cepha-btn-primary', 'cepha-btn-secondary');
        });
        btn.classList.add('active');
        btn.className = btn.className.replace('cepha-btn-secondary', 'cepha-btn-primary');
        _activeLevel = btn.getAttribute('data-level');
        updateServerTab();
    });

    function levelClass(lvl) {
        switch ((lvl || '').toUpperCase()) {
            case 'FATAL': return 'cepha-log-row-fatal';
            case 'ERROR': return 'cepha-log-row-error';
            case 'WARN': return 'cepha-log-row-warn';
            case 'INFO': return 'cepha-log-row-info';
            case 'DEBUG': return 'cepha-log-row-debug';
            case 'TRACE': return 'cepha-log-row-trace';
            default: return '';
        }
    }

    function levelBadgeClass(lvl) {
        switch ((lvl || '').toUpperCase()) {
            case 'FATAL': return 'cepha-log-level cepha-log-level-fatal';
            case 'ERROR': return 'cepha-log-level cepha-log-level-error';
            case 'WARN': return 'cepha-log-level cepha-log-level-warn';
            case 'INFO': return 'cepha-log-level cepha-log-level-info';
            case 'DEBUG': return 'cepha-log-level cepha-log-level-debug';
            default: return 'cepha-log-level';
        }
    }

    function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

    function updateServerTab() {
        if (typeof CephaSysLog === 'undefined') return;
        var opts = { limit: 500 };
        if (_activeLevel !== 'ALL') opts.level = _activeLevel;
        var all = CephaSysLog.query(opts).filter(function(e) {
            return e.category !== 'SEC' && e.category !== 'REPAIR';
        });

        var tbody = document.getElementById('server-log-body');
        var noLogs = document.getElementById('cepha-no-logs');
        var countEl = document.getElementById('cepha-log-count');
        if (!tbody) return;

        if (all.length === 0) {
            tbody.innerHTML = '';
            if (noLogs) noLogs.style.display = '';
            if (countEl) countEl.textContent = '0 entries';
            return;
        }
        if (noLogs) noLogs.style.display = 'none';

        var html = '';
        for (var i = all.length - 1; i >= 0; i--) {
            var e = all[i];
            var cls = levelClass(e.level);
            var ts = e.timestamp ? e.timestamp.replace('T', ' ').substring(0, 19) : '';
            html += '<tr class="' + cls + '">';
            html += '<td>' + esc(ts) + '</td>';
            html += '<td><span class="' + levelBadgeClass(e.level) + '">' + esc(e.level) + '</span></td>';
            html += '<td><span class="cepha-badge" style="font-size:.7rem">' + esc(e.category) + '</span></td>';
            html += '<td>' + esc(e.message) + '</td>';
            html += '</tr>';
        }
        tbody.innerHTML = html;
        if (countEl) countEl.textContent = all.length + ' entries';
    }

    function updateSecurityTab() {
        if (typeof CephaSysLog === 'undefined') return;
        var secEntries = CephaSysLog.query({ category: 'SEC', limit: 200 });
        var tbody = document.getElementById('sec-log-body');
        var noLogs = document.getElementById('sec-no-logs');
        if (!tbody) return;
        if (secEntries.length === 0) { if (noLogs) noLogs.style.display = ''; return; }
        if (noLogs) noLogs.style.display = 'none';

        var html = '';
        for (var i = secEntries.length - 1; i >= 0; i--) {
            var e = secEntries[i];
            var cls = levelClass(e.level);
            var ts = e.timestamp ? e.timestamp.replace('T', ' ').substring(0, 19) : '';
            html += '<tr class="' + cls + '">';
            html += '<td>' + esc(ts) + '</td>';
            html += '<td><span class="' + levelBadgeClass(e.level) + '">' + esc(e.level) + '</span></td>';
            html += '<td>' + esc(e.violationType) + '</td>';
            html += '<td>' + esc(e.message) + '</td>';
            html += '<td style="font-size:.7rem;opacity:.7">' + esc(e.domPath) + '</td>';
            html += '</tr>';
        }
        tbody.innerHTML = html;
        var countEl = document.getElementById('sec-count');
        if (countEl) countEl.textContent = secEntries.length + ' violation' + (secEntries.length !== 1 ? 's' : '');

        var enfEl = document.getElementById('sec-enforced');
        if (enfEl && typeof CephaSecurity !== 'undefined') {
            var enf = CephaSecurity.isEnforcementEnabled();
            enfEl.textContent = enf ? '🔒 Enforced' : '👁️ Monitor Only';
            enfEl.style.background = enf ? '#4caf50' : '#ff9800';
        }
    }

    function updateRepairsTab() {
        if (typeof CephaSysLog === 'undefined') return;
        var repairEntries = CephaSysLog.query({ category: 'REPAIR', limit: 200 });
        var tbody = document.getElementById('repair-log-body');
        var noLogs = document.getElementById('repair-no-logs');
        if (!tbody) return;
        if (repairEntries.length === 0) { if (noLogs) noLogs.style.display = ''; return; }
        if (noLogs) noLogs.style.display = 'none';

        var html = '';
        for (var i = repairEntries.length - 1; i >= 0; i--) {
            var e = repairEntries[i];
            var ok = e.context && e.context.repaired;
            var statusColor = ok ? '#4caf50' : '#ff9800';
            var ts = e.timestamp ? e.timestamp.replace('T', ' ').substring(0, 19) : '';
            html += '<tr>';
            html += '<td>' + esc(ts) + '</td>';
            html += '<td><span class="cepha-badge" style="background:' + statusColor + ';color:#fff;font-size:.7rem">' + (ok ? '✅ Fixed' : '🔄 Healed') + '</span></td>';
            html += '<td>' + esc(e.violationType) + '</td>';
            html += '<td>' + esc(e.repairAction || e.message) + '</td>';
            html += '<td style="font-size:.7rem;opacity:.7">' + esc(e.domPath) + '</td>';
            html += '</tr>';
        }
        tbody.innerHTML = html;

        var countEl = document.getElementById('repair-count');
        if (countEl) countEl.textContent = repairEntries.length + ' repair' + (repairEntries.length !== 1 ? 's' : '');

        var pendingEl = document.getElementById('repair-pending');
        if (pendingEl && typeof CephaSecurity !== 'undefined') {
            var pending = CephaSecurity.getPendingRepairCount();
            pendingEl.textContent = pending + ' pending';
        }
    }

    function updateAnomalyTab() {
        if (typeof CephaSysLog === 'undefined') return;
        var summary = CephaSysLog.getAnomalySummary();

        var violEl = document.getElementById('anomaly-violations');
        var repairEl = document.getElementById('anomaly-repairs');
        var failedEl = document.getElementById('anomaly-failed');
        if (violEl) violEl.textContent = summary.totalViolations;
        if (repairEl) repairEl.textContent = summary.successfulRepairs;
        if (failedEl) failedEl.textContent = summary.failedRepairs;

        var byTypeEl = document.getElementById('anomaly-by-type');
        if (byTypeEl) {
            var types = summary.violationsByType;
            var maxVal = Math.max(1, ...Object.values(types));
            var typeHtml = '';
            var typeColors = { script_injection: '#f44336', iframe_injection: '#f44336', input_type_change: '#f44336', integrity_hash_mismatch: '#f44336', stream_desync: '#e91e63', secure_element_modified: '#ff9800', locked_field_unhidden: '#ff9800', secure_element_removed: '#ff9800', secure_text_modified: '#2196f3', devtools_opened: '#9c27b0' };
            for (var type in types) {
                var pct = Math.round((types[type] / maxVal) * 100);
                var barColor = typeColors[type] || '#667eea';
                typeHtml += '<div style="display:flex;align-items:center;gap:.5rem;margin-bottom:4px"><span style="min-width:180px;font-size:.75rem;font-family:var(--cepha-font-mono);color:var(--cepha-text)">' + esc(type) + '</span><div class="anomaly-bar" style="width:' + Math.max(pct, 10) + '%;background:' + barColor + '">' + types[type] + '</div></div>';
            }
            byTypeEl.innerHTML = typeHtml || '<p class="cepha-caption" style="padding:1rem;text-align:center">No anomalies recorded.</p>';
        }

        var byLevelEl = document.getElementById('anomaly-by-level');
        if (byLevelEl) {
            var levels = summary.violationsByLevel;
            var maxLvl = Math.max(1, ...Object.values(levels));
            var levelHtml = '';
            var levelColors = { FATAL: '#b71c1c', ERROR: '#f44336', WARN: '#ff9800', INFO: '#2196f3', DEBUG: '#9e9e9e' };
            for (var lvl in levels) {
                var lpct = Math.round((levels[lvl] / maxLvl) * 100);
                levelHtml += '<div style="display:flex;align-items:center;gap:.5rem;margin-bottom:4px"><span style="min-width:60px;font-size:.75rem;font-weight:700;color:var(--cepha-text)">' + esc(lvl) + '</span><div class="anomaly-bar" style="width:' + Math.max(lpct, 10) + '%;background:' + (levelColors[lvl] || '#667eea') + '">' + levels[lvl] + '</div></div>';
            }
            byLevelEl.innerHTML = levelHtml || '<p class="cepha-caption" style="padding:1rem;text-align:center">No anomalies recorded.</p>';
        }
    }

    function updateSessionBadge() {
        if (typeof CephaSysLog === 'undefined') return;
        var badge = document.getElementById('syslog-session');
        if (badge) {
            var sid = CephaSysLog.getSessionId();
            var count = CephaSysLog.getEntryCount();
            badge.textContent = '📋 Session: ' + (sid || '—') + ' (' + count + ' entries)';
        }
    }

    function scheduleUpdate() {
        if (_updatePending) return;
        _updatePending = true;
        requestAnimationFrame(function() {
            _updatePending = false;
            updateAll();
        });
    }

    function updateAll() {
        updateServerTab();
        updateSecurityTab();
        updateRepairsTab();
        updateAnomalyTab();
        updateSessionBadge();
        // Notify Material UI that DOM was intentionally updated (prevents stream_desync)
        if (typeof CephaMaterial !== 'undefined' && CephaMaterial.notifyDomUpdate) {
            CephaMaterial.notifyDomUpdate();
        }
    }

    // JSONL Export — event delegation
    document.addEventListener('click', function(e) {
        var btn = e.target.closest('#anomaly-export-btn');
        if (!btn) return;
        if (typeof CephaSysLog === 'undefined') return;
        var jsonl = CephaSysLog.exportJsonLines({ category: 'SEC' });
        if (!jsonl) { alert('No security data to export.'); return; }
        var blob = new Blob([jsonl], { type: 'application/jsonlines' });
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = 'cepha-syslog-anomalies-' + new Date().toISOString().slice(0, 10) + '.jsonl';
        a.click();
        URL.revokeObjectURL(url);
    });

    // Real-time listener (debounced)
    if (typeof CephaSysLog !== 'undefined') {
        CephaSysLog.on('*', scheduleUpdate);
    }

    // Register logs page components with MaterialDb
    if (typeof CephaMaterialDb !== 'undefined' && CephaMaterialDb.isInitialized()) {
        CephaMaterialDb.registerComponent({
            id: 'logs-dashboard', name: 'Logs Dashboard', type: 'page',
            route: '/cepha/logs', metadata: { tabs: ['server','security','repairs','anomaly'] }
        });
        CephaMaterialDb.storeIntegritySnapshot('logs-dashboard', '.cepha-logs-tabs');
    }

    // Periodic refresh
    setInterval(scheduleUpdate, 3000);

    // First paint
    setTimeout(updateAll, 300);
})();
</script>